---
import { getEntry, render } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import '../styles/blog-theme.css';

const profile = await getEntry('profile', 'about');

if (!profile) {
	throw new Error('Profile content was not found.');
}

const { Content } = await render(profile);
const { title, description, updatedDate, heroImage } = profile.data;
---

<!doctype html>
<html lang="ja" data-blog-page>
	<head>
		<BaseHead title={`${title} | mizuame`} description={description} image={heroImage} />
	</head>
	<body>
		<main class="profile-page">
			<nav class="profile-nav" aria-label="Breadcrumb">
				<div class="profile-breadcrumb">
					<a href="/">HOME</a>
					<span>/</span>
					<span>PROFILE</span>
				</div>
			</nav>

			<header class="profile-hero">
				<p class="profile-kicker">PROFILE</p>
				<h1>{title}</h1>
				<p class="profile-description">{description}</p>
				{
					updatedDate && (
						<p class="profile-updated">
							最終更新 <FormattedDate date={updatedDate} lang="ja" />
						</p>
					)
				}
			</header>

			<article class="profile-article prose">
				<Content />
			</article>

			<div class="back-to-list">
				<a href="/">トップへ</a>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	:global(body) {
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 249, 250, 0.98)),
			repeating-linear-gradient(90deg, rgba(35, 55, 255, 0.06) 0 1px, transparent 1px 72px);
	}

	.profile-page {
		width: min(100% - 2rem, 980px);
		margin: 0 auto;
		padding: 2rem 0 5rem;
	}

	.profile-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 3.5rem;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		color: var(--blog-text-muted);
	}

	.profile-breadcrumb {
		display: flex;
		align-items: center;
		gap: 0.65rem;
	}

	.profile-nav a {
		color: var(--blog-text);
		text-decoration: none;
	}

	.profile-nav a:hover {
		color: var(--blog-link);
	}

	.profile-hero {
		display: grid;
		gap: 1rem;
		padding-bottom: 2.5rem;
		border-bottom: 1px solid var(--blog-border);
	}

	.profile-kicker {
		margin: 0;
		font-size: 0.82rem;
		font-weight: 900;
		letter-spacing: 0.16em;
		color: var(--blog-link) !important;
	}

	.profile-hero h1 {
		max-width: 10em;
		margin: 0;
		font-size: clamp(3rem, 9vw, 6.25rem);
		line-height: 0.95;
		letter-spacing: 0;
	}

	.profile-description {
		max-width: 44rem;
		margin: 0;
		font-size: clamp(1.05rem, 2vw, 1.35rem);
		line-height: 1.8;
		color: var(--blog-text-muted) !important;
	}

	.profile-updated {
		margin: 0;
		font-size: 0.9rem;
		color: var(--blog-text-muted) !important;
	}

	.profile-article {
		width: min(100%, 760px);
		margin: 3rem auto 0;
		padding: 0;
	}

	.profile-article :global(h2) {
		margin-top: 3rem;
		padding-top: 1.25rem;
		border-top: 1px solid var(--blog-border);
		font-size: clamp(1.65rem, 4vw, 2.35rem);
	}

	.profile-article :global(h3) {
		margin-top: 2rem;
		font-size: clamp(1.25rem, 3vw, 1.55rem);
	}

	.profile-article :global(p),
	.profile-article :global(li) {
		line-height: 1.9;
	}

	.profile-article :global(ul) {
		padding-left: 1.25rem;
	}

	.profile-article :global(img) {
		display: block;
		width: min(100%, 560px);
		margin: 0 auto 1.25rem;
		border-radius: 8px;
		box-shadow: 0 18px 48px rgba(34, 41, 57, 0.16);
	}

	.profile-article :global(a) {
		text-underline-offset: 0.18em;
	}

	.profile-article :global(code) {
		font-size: 0.9em;
	}

	.back-to-list {
		text-align: center;
		margin-top: 2em;
		margin-bottom: 2em;
	}

	.back-to-list a {
		display: inline-block;
		padding: 0.5em 1em;
		border-radius: 4px;
		text-decoration: none;
	}

	@media (max-width: 720px) {
		.profile-page {
			width: min(100% - 1.25rem, 980px);
			padding-top: 1.25rem;
		}

		.profile-nav {
			margin-bottom: 2.25rem;
			align-items: flex-start;
			flex-direction: column;
		}

		.profile-hero {
			padding-bottom: 2rem;
		}

		.profile-article {
			margin-top: 2rem;
		}
	}
</style>
